# ─────────────────────────────────────────────────────────────
# Directory
# ─────────────────────────────────────────────────────────────

# Create and cd into directory
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# ─────────────────────────────────────────────────────────────
# Archives
# ─────────────────────────────────────────────────────────────

# Extract any archive
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2) tar xjf "$1" ;;
            *.tar.gz)  tar xzf "$1" ;;
            *.tar.xz)  tar xJf "$1" ;;
            *.bz2)     bunzip2 "$1" ;;
            *.gz)      gunzip "$1" ;;
            *.tar)     tar xf "$1" ;;
            *.tbz2)    tar xjf "$1" ;;
            *.tgz)     tar xzf "$1" ;;
            *.zip)     unzip "$1" ;;
            *.7z)      7z x "$1" ;;
            *.rar)     unrar x "$1" ;;
            *)         echo "Unknown archive format: $1" ;;
        esac
    else
        echo "File not found: $1"
    fi
}

# Compress to tar.gz
compress() {
    tar -czf "${1%/}.tar.gz" "${1%/}"
}

# Decompress tar.gz
alias decompress="tar -xzf"

# ─────────────────────────────────────────────────────────────
# Search
# ─────────────────────────────────────────────────────────────

# Find file by name
f() {
    find . -name "*$1*" 2>/dev/null
}

# Grep in files
gr() {
    grep -rn "$1" . 2>/dev/null
}

