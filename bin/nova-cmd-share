#!/bin/bash

# Share clipboard, file, or folder using localsend-go (LocalSend protocol).
# Works with LocalSend app on iOS/Android/desktop.
#
# Usage: nova-cmd-share [clipboard|file|folder|receive]

SEND_CMD="localsend-go"

if ! command -v "$SEND_CMD" &>/dev/null; then
    notify-send -u critical "LocalSend" "localsend-go not found. Install with: go install github.com/meowrain/localsend-go@latest"
    exit 1
fi

MODE="${1:-clipboard}"
shift 2>/dev/null

case "$MODE" in
    clipboard)
        TEMP_FILE=$(mktemp --suffix=.txt)
        wl-paste > "$TEMP_FILE"
        if [[ ! -s "$TEMP_FILE" ]]; then
            rm -f "$TEMP_FILE"
            notify-send "Share" "Clipboard is empty"
            exit 0
        fi
        "$SEND_CMD" send "$TEMP_FILE"
        rm -f "$TEMP_FILE"
        ;;
    file)
        if (($# > 0)); then
            "$SEND_CMD" send "$@"
        else
            FILE=$(find "$HOME" -maxdepth 4 -type f 2>/dev/null | fzf --prompt="Select file: ")
            [[ -z "$FILE" ]] && exit 0
            "$SEND_CMD" send "$FILE"
        fi
        ;;
    folder)
        if (($# > 0)); then
            "$SEND_CMD" send "$@"
        else
            FOLDER=$(find "$HOME" -maxdepth 4 -type d 2>/dev/null | fzf --prompt="Select folder: ")
            [[ -z "$FOLDER" ]] && exit 0
            "$SEND_CMD" send "$FOLDER"
        fi
        ;;
    receive)
        "$SEND_CMD" receive
        ;;
    *)
        echo "Usage: nova-cmd-share [clipboard|file|folder|receive]"
        exit 1
        ;;
esac
